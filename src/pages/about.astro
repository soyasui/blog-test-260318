---
import Layout from '../layouts/Layout.astro';
// 必要なデータだけ残す
const pageTitle = "私について";

const identity = {
  firstName: "サラ",
  country: "カナダ",
  occupation: "技術ライター",
  hobbies: ["写真", "バードウォッチング", "野球"],
};

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "ドキュメントの執筆"];

const happy = false;
const finished = true;
const goal = 3;
---

<Layout >

  <main>
    <style>
      h1 {
        color: purple;
        font-size: 4rem;
      }
      .skill {
        color: green;
        font-weight: bold;
      }
    </style>

    <h1>{pageTitle}</h1>
    <h2>ここでは私について知ってもらう</h2>
    <p>ここに好きな文章を書く。</p>
    <p>以下は私に関するいくつかの事実です。</p>
    
    <ul>
      <li>私の名前は{identity.firstName}です。</li>
      <li>{identity.country}に住んでおり、{identity.occupation}として働いています。</li>
      {identity.hobbies.length >= 2 && (
        <li>私の趣味のうち2つは、{identity.hobbies[0]}と{identity.hobbies[1]}です。</li>
      )}
    </ul>

    <p>私のスキルは以下の通りです：</p>
    <ul>
      {skills.map((skill) => <li class="skill">{skill}</li>)}
    </ul>

    <a href="/blog">ブログを見に行く</a>

    {happy && <p>Astroを学べて幸せです！</p>}
    {finished && <p>このチュートリアルを終えました！</p>}
    {goal === 3 ? <p>3日で終えるのが目標です。</p> : <p>3日が目標ではありません。</p>}
  </main>
 <slot />
</Layout>